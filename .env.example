# Base URL de l'API (sans slash final)
#
# Dev local avec proxy Vite (API sur port 5121) → requêtes passent par le serveur Vite, pas de CORS :
# VITE_API_BASE_URL=/v2/api
#
# Prod ou API sur une autre origine :
# VITE_API_BASE_URL=https://api.example.com/v2/api
VITE_API_BASE_URL=/v2/api

# Clé publique FedaPay (widget de paiement)
# Sandbox : récupérer sur https://fedapay.com
VITE_FEDAPAY_PUBLIC_KEY=pk_sandbox_xxx
VITE_FEDAPAY_ENV=sandbox
